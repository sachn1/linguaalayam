DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linguaalayam
# DB_SSLMODE=require   # uncomment for hosted Postgres (Supabase etc.)

ANTHROPIC_API_KEY=sk-ant-...   # optional — only needed for llm=anthropic
# OPENAI_API_KEY=sk-...        # optional — only needed for llm=openai

# Windows (WSL) users — optionally store secrets in Windows Credential Manager
# instead of writing them here:
#   New-StoredCredential -Target "DB_PASSWORD"       -UserName x -Password yourpassword -Persist LocalMachine
#   New-StoredCredential -Target "ANTHROPIC_API_KEY" -UserName x -Password sk-ant-...   -Persist LocalMachine
# Then add retrieval to ~/.bashrc — see docs/setup.md
